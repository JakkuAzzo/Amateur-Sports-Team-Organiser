FLASK_APP=wsgi.py
FLASK_DEBUG=1
SECRET_KEY=change-me-in-prod

# Postgres in docker-compose
POSTGRES_USER=sports
POSTGRES_PASSWORD=sports_pw
POSTGRES_DB=sportsdb
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# SQLAlchemy URL used by the Flask app
DATABASE_URL=postgresql+psycopg2://sports:sports_pw@localhost:5432/sportsdb

# Email notifications via Formsubmit.co
FORMSUBMIT_ENABLED=0
FORMSUBMIT_PER_USER=0
FORMSUBMIT_RECIPIENT=
FORMSUBMIT_FROM=no-reply@asto.local
FORMSUBMIT_SENDER_NAME=ASTO Notifications
FORMSUBMIT_SUBJECT_PREFIX=[ASTO]
